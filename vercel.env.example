# Paste into Vercel → Project → Settings → Environment Variables
# Or use "Import .env" and upload this file (after filling secrets).
# Scope: Production (and Preview if you want staging).

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

LLM_API_BASE=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_REPLACE_WITH_GROQ_KEY
LLM_MODEL=llama-3.1-8b-instant
LLM_ORDER=api

EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

SITE_BOT_ENABLED=true
PUBLIC_CHAT_API_KEY=REPLACE_WITH_32_CHAR_RANDOM_SECRET
INGEST_API_KEY=REPLACE_WITH_ANOTHER_RANDOM_SECRET
SITE_COMPANY_NAME=Infigo Solutions
SITE_CONTACT_EMAIL=hello@infigosolutions.com
SITE_BOOKING_URL=
SITE_PROPOSAL_URL=https://infigosolutions.com/
CORS_ALLOWED_ORIGINS=https://infigosolutions.com,https://www.infigosolutions.com

# Runtime website fetch (no JSON, no DB) — default
SITE_RUNTIME_FETCH_ENABLED=true
SITE_FETCH_URL=https://infigosolutions.com/
SITE_CONTENT_ENABLED=false
# Optional later: bundled JSON — set SITE_CONTENT_ENABLED=true and SITE_CONTENT_JSON=config/infigo_site_content.json
